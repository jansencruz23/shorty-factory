# NVIDIA Build API (OpenAI-compatible endpoint).
# Get a key at https://build.nvidia.com — free tier covers light usage.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Composer model — must support function calling for structured output.
# Strong defaults on NVIDIA Build: meta/llama-3.3-70b-instruct,
# nvidia/llama-3.3-nemotron-super-49b-v1, mistralai/mixtral-8x22b-instruct-v0.1.
COMPOSER_MODEL=meta/llama-3.3-70b-instruct

# Where Playwright reads the saved Meta session from.
META_STORAGE_STATE=storage_state.json

# Run Playwright headed (recommended) vs headless. Meta's anti-bot is harsher
# on headless; only flip to "true" if you're running under xvfb.
PLAYWRIGHT_HEADLESS=false

# Hard ceiling on Meta AI generations per job (defensive).
MAX_SCENES=8

# Public base URL the API advertises in result_url responses.
PUBLIC_BASE_URL=http://localhost:8000

# Caption font (Windows default works out of the box; bundle Inter-Bold.ttf
# in assets/fonts/ to override).
CAPTION_FONT_PATH=assets/fonts/Inter-Bold.ttf
CAPTION_FONT_FALLBACK=C:/Windows/Fonts/arialbd.ttf