# Nested settings flatten to env vars via the `__` (double-underscore)
# delimiter — e.g. settings.llm.nvidia_api_key reads from LLM__NVIDIA_API_KEY.
# Cross-cutting fields (paths, public URL, max scenes) stay flat.

# --- LLM (composer) ---
# NVIDIA Build API (OpenAI-compatible endpoint).
# Get a key at https://build.nvidia.com — free tier covers light usage.
LLM__NVIDIA_API_KEY=
LLM__NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Llama 3.3 70B and Nemotron support tool calling on NVIDIA Build.
LLM__COMPOSER_MODEL=meta/llama-3.3-70b-instruct

# --- Video (output dimensions + which provider generates clips) ---
VIDEO__PROVIDER=meta_ai
VIDEO__WIDTH=1080
VIDEO__HEIGHT=1920

# --- Meta.ai (only consulted when video.provider=meta_ai) ---
META_AI__STORAGE_STATE=storage_state.json
META_AI__HEADLESS=false

# --- Music (default provider + master gain at mux) ---
# "musicgen" uses MusicGen (no Content ID risk, slow on CPU).
# "local" uses files from assets/music/<niche>/.
MUSIC__PROVIDER=musicgen
MUSIC__GAIN_DB=-8.0

# --- Caption (POV overlay font) ---
CAPTION__FONT_PATH=assets/fonts/Inter-Bold.ttf
CAPTION__FONT_FALLBACK=C:/Windows/Fonts/arialbd.ttf
CAPTION__FONT_SIZE=64

# --- LangSmith observability ---
# Flip LANGSMITH__TRACING to true and add the API key (from
# https://smith.langchain.com → Settings → API Keys) to capture every
# LLM call, graph run, and Playwright/ffmpeg span.
LANGSMITH__TRACING=false
LANGSMITH__API_KEY=
LANGSMITH__PROJECT=shorty-factory
LANGSMITH__ENDPOINT=https://api.smith.langchain.com

# --- Cross-cutting flat fields ---
MAX_SCENES=8
PUBLIC_BASE_URL=http://localhost:8000
